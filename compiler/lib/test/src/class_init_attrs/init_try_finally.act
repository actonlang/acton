# Test case: Finally block always executes so assignments there count
class TestClass(object):
    x: int
    y: int
    
    def __init__(self):
        try:
            # Some operation that might fail
            print("Trying something...")
        finally:
            # These always execute
            self.x = 1
            self.y = 2

actor main(env):
    t = TestClass()
    print("x =", t.x, "y =", t.y)
    env.exit(0)