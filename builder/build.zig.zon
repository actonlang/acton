.{
    .name = .{{name}},
    .version = "0.0.0",
    .fingerprint = {{fingerprint}},
    .minimum_zig_version = "0.16.0",
    .dependencies = .{
        // Dependencies from Build.act
        // base dependencies
        .actondb = .{
            .path = "{{syspath}}/backend/",
        },
        .base = .{
            .path = "{{syspath}}/base/",
        },
    },
    .paths = .{""},
}
