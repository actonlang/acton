        return True

def test_empty_str_rjust():
    s = ""
    result = s.rjust(5)
    print("empty str.rjust(5):", repr(result))
    return result == "     "

def test_empty_str_rpartition():
    s = ""
    sp = s.rpartition("a")
    print("empty str.rpartition('a'):", sp)
    return sp.0 == "" and sp.1 == "" and sp.2 == ""

def test_empty_str_rstrip():
