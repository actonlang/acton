
def test_lt():
    return (1, 2) < (1, 3) and (1, 2) < (2, 0) and not (1, 2) < (1, 2)

def test_le():
    return (1, 2) <= (1, 2) and (1, 2) <= (1, 3) and not (1, 3) <= (1, 2)

def test_gt():
    return (1, 3) > (1, 2) and not (1, 2) > (1, 2)

def test_ge():
    return (1, 2) >= (1, 2) and (1, 3) >= (1, 2) and not (1, 2) >= (1, 3)

def test_lexicographic():
    return ("a", 9) < ("b", 0) and (1, "a") < (1, "b")

def test_nested():
    return (1, (2, 3)) < (1, (2, 4)) and not (1, (2, 4)) < (1, (2, 4))

def test_named():
    return (x=1, y=2) < (x=1, y=3)

def test_sorted():
    l = [(2, "b"), (1, "c"), (2, "a"), (1, "a")]
    return sorted(l) == [(1, "a"), (1, "c"), (2, "a"), (2, "b")]

def test_min_max():
    l = [(2, "b"), (1, "c"), (2, "a")]
    return min(l, None) == (1, "c") and max(l, None) == (2, "b")

tests = {
    "test_lt": test_lt,
    "test_le": test_le,
    "test_gt": test_gt,
    "test_ge": test_ge,
    "test_lexicographic": test_lexicographic,
    "test_nested": test_nested,
    "test_named": test_named,
    "test_sorted": test_sorted,
    "test_min_max": test_min_max,
}

actor main(env):
    failed = []
    for name, t in tests.items():
        print("== test: " + name)
        if not t():
            print("-- FAILED test: " + name)
            failed.append(name)
        print()
    if len(failed) == 0:
        print("All {len(tests)} tests OK!")
        env.exit(0)
    else:
        print("\n{len(failed)} of {len(tests)} tests failed:")
        for name in failed:
            print(" - {name}")
        env.exit(1)
